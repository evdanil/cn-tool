[api]
endpoint = https://infoblox.example.com
verify_ssl = true
timeout = 10

[logging]
logfile = ~/cn.log
# Supported levels: DEBUG, INFO, WARNING, ERROR
# level = INFO

[report]
filename = ~/report.xlsx
auto_save = true
# lock_timeout = 120
# max_config_tab_kb = 512

[config_repo]
directory = /opt/data/configs
vendors = cisco,aruba,f5,bluecoat,viptela
regions =
excluded_dirs = old,history
history_dir = history

[gpg]
# credentials = ~/device-apply.gpg

[cache]
enabled = true
directory = ~/.cn-cache
version = 5
# check_workers = 4
# index_workers = 4
# index_executor = thread
# index_queue_size = 128
# index_batch_size = 256
# index_skip_keyword_vendors = paloalto

[theme]
# theme = default

[ad]
# enabled = true
uri = ldap://your-ad-server.example.com
user = your-user@example.com or domain\login
search_base = CN=Subnets,CN=Sites,CN=Configuration,DC=example,DC=com
# operation_timeout = 15
# connect_on_startup = false

[email]
# enabled = true
send_on_exit = false
to = some_user@example.com
# from = cn-tool@localhost
# subject = CN-Tool Execution Report
# server = smtp.example.com
# port = 587
# use_tls = true
# use_ssl = false
# use_auth = true
# user = my_account@example.com
# password = app-password-or-service-password

[sdwan_yaml_search]
enabled = false
# repository_paths = /path/to/repo1,/path/to/repo2

[config_analyzer]
# repo_directories = /path/to/repoA,/path/to/repoB
# repo_names = repoA,repoB
# layout = right
# scroll_to_end = false
# debug = false
